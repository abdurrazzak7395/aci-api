      "item": [
        {
          "name": "POST /api/auth/login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"{{login}}\",\n  \"password\": \"{{password}}\",\n  \"otpMethod\": \"{{otpMethod}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Triggers OTP delivery using the SVP login flow through your backend."
          },
          "response": []
        },
        {
          "name": "POST /api/auth/otp-verify",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                  "  if (json.user && json.user.svpUserId) pm.collectionVariables.set('svpUserId', String(json.user.svpUserId));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"{{login}}\",\n  \"password\": \"{{password}}\",\n  \"otpAttempt\": \"{{otpAttempt}}\",\n  \"otpMethod\": \"{{otpMethod}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/otp-verify",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "otp-verify"
              ]
            },
            "description": "Verifies the OTP. On success Postman stores accessToken and svpUserId as collection variables. Refresh cookies are also set by the backend."
          },
          "response": []
        },
        {
          "name": "POST /api/auth/refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/refresh",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "refresh"
              ]
            },
            "description": "Uses the HttpOnly cookies set during OTP verify to issue a new access token."
          },
          "response": []
        },
        {
          "name": "POST /api/auth/logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "logout"
              ]
            },
            "description": "Revokes the current session and clears refresh cookies."
          },
          "response": []
        }
